# Dockerfile.dev — ambiente de DESENVOLVIMENTO (hot reload)
# Roda o Vite dev server dentro do container. O codigo-fonte e montado
# por volume no docker-compose, entao alteracoes refletem na hora.
FROM node:22-alpine

WORKDIR /app

# Instala dependencias primeiro (cache de camada): so reinstala quando o
# package*.json muda, nao a cada alteracao de codigo.
COPY package.json package-lock.json ./
RUN npm ci

# O restante do codigo vem via bind mount (ver docker-compose.yml).
# Copiamos aqui tambem para o caso de rodar a imagem sem o mount.
COPY . .

EXPOSE 3000

# usePolling e necessario para o file-watching funcionar dentro do container
# (especialmente em hosts Windows/macOS via Docker Desktop).
ENV CHOKIDAR_USEPOLLING=true

CMD ["npm", "run", "dev"]
